# =============================================================================
# UH SocialDash - Environment Variables Template
# =============================================================================
# Copia este archivo a .env y completa los valores reales
# Command: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos
DATABASE_URL=postgresql://uh_socialdash:your_password_here@localhost:5432/uh_socialdash

# -----------------------------------------------------------------------------
# Instagram OAuth Configuration
# -----------------------------------------------------------------------------
# Obtén estos valores desde: https://developers.facebook.com/
# 1. Crea una app tipo "Business"
# 2. Agrega el producto "Instagram Graph API"
# 3. Configura "Instagram Basic Display" permissions
# 4. Configura los Valid OAuth Redirect URIs

INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Para producción, usa HTTPS:
# INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/auth/callback

# -----------------------------------------------------------------------------
# Encryption Configuration
# -----------------------------------------------------------------------------
# Clave de encriptación para tokens de acceso de Instagram (AES-256-GCM)
# Genera una clave segura con: openssl rand -base64 32
# ⚠️ IMPORTANTE: Usa una clave diferente en producción y guárdala de forma segura
ENCRYPTION_KEY=your_encryption_key_here_generate_with_openssl

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# URL pública de la aplicación (sin barra al final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Para producción, usa HTTPS:
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Entorno de ejecución
NODE_ENV=development

# Para producción, usa:
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Puerto en el que correrá la aplicación Next.js
PORT=3000

# =============================================================================
# ⚠️ SECURITY NOTES
# =============================================================================
# 1. NUNCA commit el archivo .env al control de versiones
# 2. Usa contraseñas fuertes y únicas (mínimo 32 caracteres)
# 3. Genera claves con: openssl rand -base64 32
# 4. Rotaciona credenciales regularmente (cada 90 días)
# 5. Usa permisos restrictivos: chmod 600 .env
# 6. No reutilices contraseñas entre servicios
# 7. En producción, siempre usa HTTPS
# 8. Mantén las variables .env.example actualizadas
# =============================================================================
